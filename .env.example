# PostgreSQL connection string (Neon Serverless)
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# Vercel Blob token for file storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Secret used to sign the JWT for the admin panel
JWT_SECRET="departamento-grimaldi-equipamentos-ti"

# Simple Admin Credentials (will be upgraded to SS0/OAuth later)
ADMIN_EMAIL="admin@company.com"
ADMIN_PASSWORD_HASH="$2a$10$..." # use bcrypt manually first or cleartext for MVP if preferred, but hashing is better. MVP: use a clear secret.
ADMIN_PASSWORD="admin" # MVP simple cleartext
